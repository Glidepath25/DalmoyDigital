#
# Docker-first defaults (for DigitalOcean droplet deployment)
#
# IMPORTANT:
# - In Docker Compose, app and db credentials are sourced from POSTGRES_* below.
# - Compose builds the app's DATABASE_URL from POSTGRES_* (host `db`, port `5432`).
# - For NextAuth, set NEXTAUTH_URL to your public URL (IP or domain)
#
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dalmoy_digital
POSTGRES_PORT=5432

# Host-side fallback for local tools outside Docker (Prisma CLI on host).
# Docker Compose overrides app DATABASE_URL internally with db:5432.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dalmoy_digital?schema=public

NEXTAUTH_SECRET=replace-with-strong-secret
NEXTAUTH_URL=http://localhost:3000

NODE_ENV=production
PORT=3000

# Local file uploads (attachments + inspection photos)
# In Docker we mount a named volume to `/app/uploads`.
UPLOAD_DIR=/app/uploads

# Optional tuning
BCRYPT_SALT_ROUNDS=12
NEXT_TELEMETRY_DISABLED=1
