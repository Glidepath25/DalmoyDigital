#
# Docker-first defaults (for DigitalOcean droplet deployment)
#
# IMPORTANT:
# - In Docker, the Postgres hostname is the service name: `db` (not `localhost`)
# - For NextAuth, set NEXTAUTH_URL to your public URL (IP or domain)
#
DATABASE_URL=postgresql://postgres:postgres@db:5432/dalmoy_digital?schema=public

NEXTAUTH_SECRET=replace-with-strong-secret
NEXTAUTH_URL=http://localhost:3000

NODE_ENV=production
PORT=3000

# Optional tuning
BCRYPT_SALT_ROUNDS=12
NEXT_TELEMETRY_DISABLED=1
