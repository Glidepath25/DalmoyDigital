generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid @map("id")
  email        String   @unique @map("email")
  name         String?
  passwordHash String?  @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roles UserRole[]

  createdClients   Client[]       @relation("client_created_by")
  updatedClients   Client[]       @relation("client_updated_by")
  createdStatuses  ProjectStatus[] @relation("status_created_by")
  updatedStatuses  ProjectStatus[] @relation("status_updated_by")
  createdLookups   LookupType[]   @relation("lookup_type_created_by")
  updatedLookups   LookupType[]   @relation("lookup_type_updated_by")
  createdOptions   LookupOption[] @relation("lookup_option_created_by")
  updatedOptions   LookupOption[] @relation("lookup_option_updated_by")
  createdProjects  Project[]      @relation("project_created_by")
  updatedProjects  Project[]      @relation("project_updated_by")

  seniorManagedProjects   Project[] @relation("project_senior_manager")
  siteManagedProjects     Project[] @relation("project_site_manager")
  contractManagedProjects Project[] @relation("project_contract_manager")

  uploadedAttachments   ProjectAttachment[]     @relation("attachment_uploaded_by")
  createdCorrespondence ProjectCorrespondence[] @relation("correspondence_created_by")

  createdMilestones ProjectMilestone[] @relation("milestone_created_by")
  updatedMilestones ProjectMilestone[] @relation("milestone_updated_by")

  ownedActionItems   ProjectActionItem[] @relation("action_owner")
  createdActionItems ProjectActionItem[] @relation("action_created_by")
  updatedActionItems ProjectActionItem[] @relation("action_updated_by")

  createdFinanceLines ProjectFinanceLine[] @relation("finance_created_by")
  updatedFinanceLines ProjectFinanceLine[] @relation("finance_updated_by")

  completedInspectionReports SiteInspectionReport[] @relation("inspection_completed_by")

  uploadedFiles StoredFile[] @relation("stored_file_uploaded_by")

  @@map("users")
}

model Role {
  id          String  @id @default(uuid()) @db.Uuid @map("id")
  key         String  @unique
  name        String
  description String?
  isSystem    Boolean @default(true) @map("is_system")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid @map("id")
  key         String  @unique
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String @db.Uuid @map("user_id")
  roleId String @db.Uuid @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @db.Uuid @map("role_id")
  permissionId String @db.Uuid @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Client {
  id        String   @id @default(uuid()) @db.Uuid @map("id")
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  archivedAt DateTime? @map("archived_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdById String? @db.Uuid @map("created_by_id")
  updatedById String? @db.Uuid @map("updated_by_id")
  createdBy   User?   @relation("client_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?   @relation("client_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  projects Project[]

  @@index([isActive, sortOrder])
  @@index([archivedAt])
  @@map("clients")
}

model ProjectStatus {
  id        String   @id @default(uuid()) @db.Uuid @map("id")
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  archivedAt DateTime? @map("archived_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdById String? @db.Uuid @map("created_by_id")
  updatedById String? @db.Uuid @map("updated_by_id")
  createdBy   User?   @relation("status_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?   @relation("status_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  projects Project[]

  @@index([isActive, sortOrder])
  @@index([archivedAt])
  @@map("project_statuses")
}

model LookupType {
  id          String   @id @default(uuid()) @db.Uuid @map("id")
  key         String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  archivedAt  DateTime? @map("archived_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdById String? @db.Uuid @map("created_by_id")
  updatedById String? @db.Uuid @map("updated_by_id")
  createdBy   User?   @relation("lookup_type_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?   @relation("lookup_type_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  options LookupOption[]

  @@index([isActive, sortOrder])
  @@map("lookup_types")
}

model LookupOption {
  id           String   @id @default(uuid()) @db.Uuid @map("id")
  lookupTypeId String   @db.Uuid @map("lookup_type_id")
  label        String
  value        String
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  archivedAt   DateTime? @map("archived_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdById String? @db.Uuid @map("created_by_id")
  updatedById String? @db.Uuid @map("updated_by_id")
  createdBy   User?   @relation("lookup_option_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?   @relation("lookup_option_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  lookupType LookupType @relation(fields: [lookupTypeId], references: [id], onDelete: Cascade)

  ragProjects                   Project[]           @relation("project_rag_option")
  attachmentCategoryAttachments ProjectAttachment[] @relation("attachment_category_option")
  milestoneRagMilestones        ProjectMilestone[]  @relation("milestone_rag_option")
  actionStatusItems             ProjectActionItem[] @relation("action_status_option")
  actionPriorityItems           ProjectActionItem[] @relation("action_priority_option")

  @@unique([lookupTypeId, value])
  @@index([lookupTypeId, isActive, sortOrder])
  @@map("lookup_options")
}

model Project {
  id        String   @id @default(uuid()) @db.Uuid @map("id")
  reference String   @unique
  name      String
  notes     String?
  dueDate   DateTime? @map("due_date")

  clientId String @db.Uuid @map("client_id")
  statusId String @db.Uuid @map("status_id")
  ragOptionId String? @db.Uuid @map("rag_option_id")

  seniorManagerUserId   String? @db.Uuid @map("senior_manager_user_id")
  siteManagerUserId     String? @db.Uuid @map("site_manager_user_id")
  contractManagerUserId String? @db.Uuid @map("contract_manager_user_id")

  client Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  status ProjectStatus @relation(fields: [statusId], references: [id], onDelete: Restrict)
  ragOption LookupOption? @relation("project_rag_option", fields: [ragOptionId], references: [id], onDelete: SetNull)

  seniorManagerUser   User? @relation("project_senior_manager", fields: [seniorManagerUserId], references: [id], onDelete: SetNull)
  siteManagerUser     User? @relation("project_site_manager", fields: [siteManagerUserId], references: [id], onDelete: SetNull)
  contractManagerUser User? @relation("project_contract_manager", fields: [contractManagerUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdById String? @db.Uuid @map("created_by_id")
  updatedById String? @db.Uuid @map("updated_by_id")
  createdBy   User?   @relation("project_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?   @relation("project_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  correspondence ProjectCorrespondence[]
  milestones     ProjectMilestone[]
  actionItems    ProjectActionItem[]
  financeLines   ProjectFinanceLine[]
  attachments    ProjectAttachment[]
  inspectionReports SiteInspectionReport[]

  @@index([clientId])
  @@index([statusId])
  @@index([dueDate])
  @@index([ragOptionId])
  @@map("projects")
}

model StoredFile {
  id              String   @id @default(uuid()) @db.Uuid @map("id")
  storageProvider String   @map("storage_provider")
  storageKey      String   @unique @map("storage_key")
  originalName    String   @map("original_name")
  mimeType        String?  @map("mime_type")
  sizeBytes       Int?     @map("size_bytes")

  uploadedById String? @db.Uuid @map("uploaded_by_id")
  uploadedBy   User?   @relation("stored_file_uploaded_by", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  attachments ProjectAttachment[]
  inspectionItemPhotos SiteInspectionItem[] @relation("inspection_item_photo")

  @@map("stored_files")
}

model ProjectAttachment {
  id        String @id @default(uuid()) @db.Uuid @map("id")
  projectId String @db.Uuid @map("project_id")
  fileId    String @db.Uuid @map("file_id")
  categoryOptionId String? @db.Uuid @map("category_option_id")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file    StoredFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  categoryOption LookupOption? @relation("attachment_category_option", fields: [categoryOptionId], references: [id], onDelete: SetNull)

  uploadedById String? @db.Uuid @map("uploaded_by_id")
  uploadedBy   User?   @relation("attachment_uploaded_by", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([categoryOptionId])
  @@map("project_attachments")
}

model ProjectCorrespondence {
  id        String @id @default(uuid()) @db.Uuid @map("id")
  projectId String @db.Uuid @map("project_id")

  fromAddress String @map("from_address")
  toAddress   String @map("to_address")
  subject     String @map("subject")
  bodyText    String? @map("body_text")
  aiSummary   String? @map("ai_summary")
  occurredAt  DateTime @map("occurred_at")

  sourceType String @map("source_type") // manual | inbound_email | outbound_email
  externalMessageId String? @map("external_message_id")
  externalThreadId  String? @map("external_thread_id")
  provider          String? @map("provider")

  createdById String? @db.Uuid @map("created_by_id")
  createdBy   User?   @relation("correspondence_created_by", fields: [createdById], references: [id], onDelete: SetNull)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId, occurredAt])
  @@map("project_correspondence")
}

model ProjectMilestone {
  id        String @id @default(uuid()) @db.Uuid @map("id")
  projectId String @db.Uuid @map("project_id")

  milestoneKey String @map("milestone_key")
  milestoneName String @map("milestone_name")
  sortOrder Int @default(0) @map("sort_order")

  ragOptionId String? @db.Uuid @map("rag_option_id")
  ragOption   LookupOption? @relation("milestone_rag_option", fields: [ragOptionId], references: [id], onDelete: SetNull)

  programStart    DateTime? @map("program_start")
  forecastStart   DateTime? @map("forecast_start")
  programFinish   DateTime? @map("program_finish")
  forecastFinish  DateTime? @map("forecast_finish")

  createdById String? @db.Uuid @map("created_by_id")
  updatedById String? @db.Uuid @map("updated_by_id")
  createdBy   User?   @relation("milestone_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?   @relation("milestone_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([projectId, milestoneKey])
  @@index([projectId, sortOrder])
  @@map("project_milestones")
}

model ProjectActionItem {
  id        String @id @default(uuid()) @db.Uuid @map("id")
  projectId String @db.Uuid @map("project_id")

  title String @map("title")
  statusOptionId String? @db.Uuid @map("status_option_id")
  priorityOptionId String? @db.Uuid @map("priority_option_id")

  ownerUserId String? @db.Uuid @map("owner_user_id")
  ownerUser   User?   @relation("action_owner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  requiredClosureDate DateTime? @map("required_closure_date")
  actualClosureDate   DateTime? @map("actual_closure_date")

  statusOption   LookupOption? @relation("action_status_option", fields: [statusOptionId], references: [id], onDelete: SetNull)
  priorityOption LookupOption? @relation("action_priority_option", fields: [priorityOptionId], references: [id], onDelete: SetNull)

  createdById String? @db.Uuid @map("created_by_id")
  updatedById String? @db.Uuid @map("updated_by_id")
  createdBy   User?   @relation("action_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?   @relation("action_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([statusOptionId])
  @@index([priorityOptionId])
  @@map("project_action_items")
}

model ProjectFinanceLine {
  id        String @id @default(uuid()) @db.Uuid @map("id")
  projectId String @db.Uuid @map("project_id")

  item     String @map("item")
  supplier String? @map("supplier")

  tenderedCost Decimal? @db.Decimal(14, 2) @map("tendered_cost")
  qty          Decimal? @db.Decimal(14, 2) @map("qty")
  actualCost   Decimal? @db.Decimal(14, 2) @map("actual_cost")
  invoicedCost Decimal? @db.Decimal(14, 2) @map("invoiced_cost")

  createdById String? @db.Uuid @map("created_by_id")
  updatedById String? @db.Uuid @map("updated_by_id")
  createdBy   User?   @relation("finance_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?   @relation("finance_updated_by", fields: [updatedById], references: [id], onDelete: SetNull)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("project_finance_lines")
}

model SiteInspectionReport {
  id        String @id @default(uuid()) @db.Uuid @map("id")
  projectId String @db.Uuid @map("project_id")

  completedByUserId String? @db.Uuid @map("completed_by_user_id")
  completedByUser   User?   @relation("inspection_completed_by", fields: [completedByUserId], references: [id], onDelete: SetNull)

  inspectionDate DateTime @map("inspection_date")
  projectReferenceSnapshot String @map("project_reference_snapshot")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   SiteInspectionItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId, inspectionDate])
  @@map("site_inspection_reports")
}

model SiteInspectionItem {
  id       String @id @default(uuid()) @db.Uuid @map("id")
  reportId String @db.Uuid @map("report_id")

  itemTitle String @map("item_title")
  comment   String? @map("comment")

  photoFileId String? @db.Uuid @map("photo_file_id")
  photoFile   StoredFile? @relation("inspection_item_photo", fields: [photoFileId], references: [id], onDelete: SetNull)

  report SiteInspectionReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([reportId])
  @@map("site_inspection_items")
}
